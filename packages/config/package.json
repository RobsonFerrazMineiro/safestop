{
  "name": "@safestop/config",
  "version": "0.1.0",
  "description": "Shared TypeScript, ESLint and Prettier configuration for the SafeStop monorepo.",
  "private": true,
  "type": "module",
  "exports": {
    "./typescript/base.json": "./typescript/base.json",
    "./typescript/library.json": "./typescript/library.json",
    "./typescript/nextjs.json": "./typescript/nextjs.json",
    "./typescript/react-native.json": "./typescript/react-native.json",
    "./eslint": "./eslint/base.js",
    "./prettier": "./prettier/index.js"
  },
  "files": [
    "typescript",
    "eslint",
    "prettier"
  ],
  "scripts": {
    "lint": "eslint .",
    "clean": "node -e \"const fs=require('fs');['dist','tsconfig.tsbuildinfo'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}))\""
  },
  "dependencies": {
    "@eslint/js": "10.0.1",
    "typescript-eslint": "8.63.0"
  }
}
